<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:PandaCubeTimer.ViewModels"
             xmlns:models="clr-namespace:PandaCubeTimer.Models"
             xmlns:dtos="clr-namespace:PandaCubeTimer.Models.DTOs"
             xmlns:converters="clr-namespace:PandaCubeTimer.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewModels:SessionsViewModel"
             Title="Sessions"
             x:Class="PandaCubeTimer.Views.SessionsView">
    
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Loaded" Command="{Binding LoadSessionsCommand}"/>
    </ContentPage.Behaviors>
    
    <ContentPage.Content>
        <Grid>
            
            <RefreshView Command="{Binding LoadSessionsCommand}"
                         IsRefreshing="{Binding IsRefreshing}"
                         Padding="5">
                
                <CollectionView Background="Transparent"
                                SelectionMode="Single" 
                                x:Name="SessionsList"
                                ItemsSource="{Binding Sessions}">
                    
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dtos:SessionDTO">
                            <Frame Padding="15">
                                
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer CommandParameter="{Binding}"
                                                          Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:SessionsViewModel}}, Path=SelectSessionCommand }"/>
                                </Frame.GestureRecognizers>
                                
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#2196F3" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="False">
                                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#2A2A2A}" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                
                                <HorizontalStackLayout Padding="0"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"
                                                       Background="Transparent">
                                    
                                    <Label x:Name="DisciplineNameLabel"
                                           Text="{Binding DisciplineName}"
                                           Padding="0"
                                           FontAutoScalingEnabled="True"
                                           FontAttributes="Bold">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="#E0E0E0" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                <Setter Property="TextColor" Value="Gray" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Line VerticalOptions="Center"
                                          BackgroundColor="Blue"></Line>

                                    <Label x:Name="SessionNameLabel"
                                           Text="{Binding Name}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="White" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light=Black, Dark=White}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    
                                </HorizontalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    
                </CollectionView>
                
            </RefreshView>
            
            <Button Text="+"
                    Command="{Binding AddSessionCommand}"
                    WidthRequest="60"
                    HeightRequest="60"
                    CornerRadius="30" 
                    BackgroundColor="{AppThemeBinding Light=#2196F3, Dark=#64B5F6}"
                    TextColor="White"
                    FontSize="28"
                    FontAttributes="Bold"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0, 0, 20, 20" />
            
            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="FillAndExpand"
                               VerticalOptions="CenterAndExpand"/> 
            
        </Grid>
    </ContentPage.Content>
    
</ContentPage>