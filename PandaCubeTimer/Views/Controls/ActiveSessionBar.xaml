<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controlViewModels="clr-namespace:PandaCubeTimer.ViewModels.ControlsVMs"
             x:Class="PandaCubeTimer.Views.Controls.ActiveSessionBar"
             x:DataType="controlViewModels:ActiveSessionBarViewModel">
    
    <Frame Background="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}" 
           Padding="15,10" 
           CornerRadius="0" 
           BorderColor="Transparent"
           HasShadow="False">
           
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
            <Label Text="Active:" 
                   TextColor="Gray" 
                   VerticalOptions="Center"/>
            
            <Label Text="{Binding ActiveSessionStore.CurrentSessionDTO.Name, FallbackValue='None Selected'}" 
                   FontAttributes="Bold" 
                   TextColor="{AppThemeBinding Light=Black, Dark=White}"
                   VerticalOptions="Center"/>
                   
            <Label Text="{Binding ActiveSessionStore.CurrentSessionDTO.DisciplineName, FallbackValue=''}" 
                   TextColor="{AppThemeBinding Light=#2196F3, Dark=#64B5F6}" 
                   VerticalOptions="Center"/>
        </HorizontalStackLayout>
    </Frame>
       
</ContentView>